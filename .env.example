# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env asla git'e commit'lenmez.

# ─── Veritabanı ───────────────────────────────────────────
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=guclu-bir-sifre-yazin

# Railway'de bu değerlerin yerine Railway'in otomatik
# enjekte ettiği DATABASE_URL kullanılır.
DATABASE_URL=postgresql://appuser:guclu-bir-sifre-yazin@localhost:5432/appdb

# ─── Backend ──────────────────────────────────────────────
# JWT secret — üretimde en az 64 karakter rastgele değer olmalı
JWT_SECRET=degistirin-cok-uzun-rastgele-bir-deger-yazin
JWT_EXPIRATION_MS=3600000

# Uygulamanın çalışacağı port
SERVER_PORT=8080

# ─── Frontend ─────────────────────────────────────────────
# Backend API base URL (Next.js için NEXT_PUBLIC_ prefix zorunlu)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Angular için (environment.ts içinde kullanılır)
API_URL=http://localhost:8080

# ─── CORS ─────────────────────────────────────────────────
# Backend'in kabul edeceği frontend origin
ALLOWED_ORIGIN=http://localhost:3000

# ─── Railway (üretim) ─────────────────────────────────────
# Railway dashboard'dan alınır — CI/CD için GitHub secret olarak eklenir
RAILWAY_TOKEN=
