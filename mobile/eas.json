{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://giderlerim.net/api/v1",
        "EXPO_PUBLIC_PLAY_SUBSCRIPTION_PRO_URL": "https://play.google.com/store/apps/details?id=com.scinar.giderlerim",
        "EXPO_PUBLIC_PLAY_SUBSCRIPTION_ULTRA_URL": "https://play.google.com/store/apps/details?id=com.scinar.giderlerim"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://giderlerim.net/api/v1",
        "EXPO_PUBLIC_PLAY_SUBSCRIPTION_PRO_URL": "https://play.google.com/store/apps/details?id=com.scinar.giderlerim",
        "EXPO_PUBLIC_PLAY_SUBSCRIPTION_ULTRA_URL": "https://play.google.com/store/apps/details?id=com.scinar.giderlerim"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
