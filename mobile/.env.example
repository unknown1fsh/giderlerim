# Giderlerim mobil — kopyalayın: cp .env.example .env
# EXPO_PUBLIC_* değişince: npx expo start -c

# ─── API (Spring /api/v1) ─────────────────────────────────────────────────
#
# Railway tek konteyner (Next + Spring): kamuya açık HTTPS kök + /api/v1
#   EXPO_PUBLIC_API_URL=https://giderlerim.net/api/v1
#
# Tanımlamazsanız apiClient varsayılanı kullanır:
#   Android emülatör → http://10.0.2.2:8081/api/v1
#   iOS Simulator    → http://127.0.0.1:8081/api/v1
#
# Fiziksel cihaz: bilgisayarda SPRING_PROFILES_ACTIVE=dev (0.0.0.0 dinleme) + LAN IP:
#   EXPO_PUBLIC_API_URL=http://192.168.1.x:8081/api/v1
#
EXPO_PUBLIC_API_URL=https://giderlerim.net/api/v1

# Shopier (web .env.example ile aynı ürün linkleri)
EXPO_PUBLIC_SHOPIER_PRO_AYLIK=https://shopier.com/ssayinovation/46065275
EXPO_PUBLIC_SHOPIER_ULTRA_AYLIK=https://shopier.com/ssayinovation/46065334
