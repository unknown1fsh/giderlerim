# ═══════════════════════════════════════════════════════════════════════════
# Giderlerim mobil — CANLI (Railway) kullanımı
# ═══════════════════════════════════════════════════════════════════════════
#
# 1) Kopyalayın: Copy-Item .env.example .env  (PowerShell, mobile klasöründe)
# 2) EXPO_PUBLIC_API_URL kendi HTTPS API adresiniz olsun.
# 3) npx expo start --clear
#
# ═══════════════════════════════════════════════════════════════════════════

EXPO_PUBLIC_API_URL=https://giderlerim.net/api/v1

# ─── Google Play (plan yükseltme — şimdilik mock URL) ───────────────────────
# Varsayılan: app.json içindeki android.package ile Play Store uygulama sayfası.
# Boş bırakırsanız kod otomatik .../details?id=com.scinar.giderlerim üretir.
#
# İleride gerçek entegrasyon: Play Billing SDK; bu env alanları yedek / test linki
# veya mağaza içi derin bağlantı için kullanılabilir.
#
EXPO_PUBLIC_PLAY_SUBSCRIPTION_PRO_URL=https://play.google.com/store/apps/details?id=com.scinar.giderlerim
EXPO_PUBLIC_PLAY_SUBSCRIPTION_ULTRA_URL=https://play.google.com/store/apps/details?id=com.scinar.giderlerim

# Tanımsız EXPO_PUBLIC_API_URL: Android emülatör / iOS Simulator varsayılanları (yerel backend)
