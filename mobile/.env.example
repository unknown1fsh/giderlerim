# ═══════════════════════════════════════════════════════════════════════════
# Giderlerim mobil — CANLI (Railway) kullanımı
# ═══════════════════════════════════════════════════════════════════════════
#
# 1) Bu dosyayı kopyalayın:
#      Windows (PowerShell, mobile klasöründe):
#        Copy-Item .env.example .env
#      veya: cp .env.example .env
#
# 2) Aşağıdaki EXPO_PUBLIC_API_URL değerini kendi kamuya açık adresinizle değiştirin
#    (Railway’de özel alan adı veya *.up.railway.app HTTPS URL’si).
#
# 3) Değişiklikten sonra Metro’yu temiz cache ile başlatın:
#      npx expo start -c
#
# 4) EAS ile APK/AAB alırken: mobile/eas.json içindeki aynı değişkenleri güncelleyin
#    veya EAS Secret tanımlayın (eas secret:create --scope project --name ...).
#
# ═══════════════════════════════════════════════════════════════════════════

# API — Spring Boot /api/v1 (Railway tek konteyner: genelde site kökü + /api/v1)
# Örnek özel alan: https://giderlerim.net/api/v1
# Örnek Railway alt alan: https://YOUR-SERVICE.up.railway.app/api/v1
EXPO_PUBLIC_API_URL=https://giderlerim.net/api/v1

# Shopier (plan yükseltme linkleri — web .env ile aynı ürünler)
EXPO_PUBLIC_SHOPIER_PRO_AYLIK=https://shopier.com/ssayinovation/46065275
EXPO_PUBLIC_SHOPIER_ULTRA_AYLIK=https://shopier.com/ssayinovation/46065334

# ─── Not: EXPO_PUBLIC_API_URL yoksa (sadece geliştirici emülatörü için) ─────
#   Android emülatör → http://10.0.2.2:8081/api/v1
#   iOS Simulator    → http://127.0.0.1:8081/api/v1
# Gerçek telefon / APK için mutlaka yukarıdaki HTTPS adresi kullanın.
