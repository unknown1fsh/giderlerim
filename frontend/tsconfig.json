{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@giderlerim/shared/*": [
        "../packages/shared/*"
      ],
      "@tanstack/react-query": [
        "./node_modules/@tanstack/react-query"
      ],
      "zustand": [
        "./node_modules/zustand"
      ],
      "zustand/*": [
        "./node_modules/zustand/*"
      ],
      "use-sync-external-store": [
        "./node_modules/use-sync-external-store"
      ],
      "use-sync-external-store/*": [
        "./node_modules/use-sync-external-store/*"
      ],
      "axios": [
        "./node_modules/axios"
      ],
      "react": [
        "./node_modules/@types/react"
      ],
      "date-fns": [
        "./node_modules/date-fns"
      ],
      "date-fns/*": [
        "./node_modules/date-fns/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
